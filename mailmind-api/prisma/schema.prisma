generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IntegrationsGoogleAccount {
  id     String  @id @default(cuid())
  userId String
  user   IamUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  googleEmail String
  scopes      String // space-delimited scopes (simple for MVP)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tokens IntegrationsGoogleToken?

  @@unique([userId, googleEmail])
}

model IntegrationsGoogleToken {
  id              String                    @id @default(cuid())
  googleAccountId String                    @unique
  googleAccount   IntegrationsGoogleAccount @relation(fields: [googleAccountId], references: [id], onDelete: Cascade)

  accessTokenEnc  String
  refreshTokenEnc String
  expiresAt       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IamUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions       IamSession[]
  googleAccounts IntegrationsGoogleAccount[]

  mailboxAccounts MailboxAccount[]
  aiAnalyses      AiAnalysis[]
  tasks           Task[]
  calendarEvents  CalendarEvent[]
  reminders       Reminder[]
  aiSuggestions   AiSuggestion[]
  notifications   Notification[]
  drafts          MailDraft[]

  /** IANA timezone, prompt'ta LLM'e veriliyor; default Türkiye */
  timezone String @default("Europe/Istanbul")
}

model IamSession {
  id     String  @id @default(cuid())
  userId String
  user   IamUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  userAgent    String?
  ip           String?
  replacedById String? // rotation: yeni session id referansı

  @@index([userId])
  @@index([expiresAt])
}

enum MailProvider {
  GMAIL
  ICLOUD
  IMAP
}

enum MailboxAccountStatus {
  PENDING
  ACTIVE
  PAUSED
  REVOKED
  ERROR
}

model MailboxAccount {
  id          String               @id @default(cuid())
  userId      String
  provider    MailProvider
  email       String
  displayName String?
  status      MailboxAccountStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user IamUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  credentials MailboxCredential?

  syncJobs MailboxSyncJob[]

  messages MailboxMessage[]
  drafts   MailDraft[]

  @@unique([provider, email])
  @@index([userId])
}

model MailboxCredential {
  id               String @id @default(cuid())
  mailboxAccountId String @unique

  // OAuth (Gmail/Outlook)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?

  // IMAP
  imapHost        String?
  imapPort        Int?
  imapUsername    String?
  imapPasswordEnc String?

  // SMTP
  smtpHost        String?
  smtpPort        Int?
  smtpUsername    String?
  smtpPasswordEnc String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mailboxAccount MailboxAccount @relation(fields: [mailboxAccountId], references: [id], onDelete: Cascade)
}

model OutboxEvent {
  id        String    @id @default(cuid())
  type      String
  payload   Json
  status    String    @default("PENDING") // PENDING|PROCESSING|DONE|FAILED
  createdAt DateTime  @default(now())
  sentAt    DateTime?

  // ── Robustness alanları (AiAnalysis ile aynı pattern) ──────────────────
  /** Şimdiye kadarki başarısız deneme sayısı. */
  attemptCount Int       @default(0)
  /** Sonraki retry'a kadar bekleme zamanı; PENDING için filter. */
  nextRetryAt  DateTime?
  /** PROCESSING durumunda atanır; stuck-job recovery bu alana bakar. */
  lockedAt     DateTime?
  /** Son hata mesajı — debug ve UI için. */
  errorMessage String?

  @@index([status, nextRetryAt]) // worker'ın "şimdi işlenebilecek" sorgusu
  @@index([status, lockedAt])    // stuck recovery sorgusu
}

enum MailboxSyncJobType {
  INITIAL
  INCREMENTAL
}

enum MailboxSyncJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model MailboxSyncJob {
  id               String               @id @default(cuid())
  mailboxAccountId String
  type             MailboxSyncJobType   @default(INITIAL)
  status           MailboxSyncJobStatus @default(PENDING)

  // sync parametreleri (şimdilik opsiyonel)
  cursor       String?
  errorMessage String?

  // Robustness alanları (startedAt zaten lockedAt rolünde — RUNNING durumda set olur)
  attemptCount Int       @default(0)
  nextRetryAt  DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?

  mailboxAccount MailboxAccount @relation(fields: [mailboxAccountId], references: [id], onDelete: Cascade)

  @@index([mailboxAccountId, status])
  @@index([status, nextRetryAt]) // worker'ın "şimdi işlenebilecek" sorgusu
}

// ─── AI & Productivity ───────────────────────────────────────────────────────

enum AiAnalysisStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model AiAnalysis {
  id               String          @id @default(cuid())
  userId           String
  /**
   * Bir mail için tek bir analiz kaydı. Aynı MESSAGE_SYNCED outbox event'i
   * iki kere işlenirse (retry, race) ikinci create unique violation alır;
   * outbox handler `createMany({ skipDuplicates: true })` ile zarif şekilde
   * yutar. Re-analiz istenirse mevcut kaydı silmek/güncellemek gerekir.
   */
  mailboxMessageId String          @unique
  status           AiAnalysisStatus @default(PENDING)
  model            String?         // örn: "llama3.1:8b"
  summary          String?         // AI'ın ürettiği kısa özet
  rawResult        Json?           // AI'dan gelen ham yanıt
  errorMessage     String?
  processedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // ── Robustness alanları ─────────────────────────────────────────────────
  /** Şimdiye kadarki başarısız deneme sayısı (3'e ulaştığında FAILED terminaldir). */
  attemptCount Int @default(0)
  /** Sonraki retry'a kadar bekleme zamanı (PENDING + nextRetryAt > now ise worker beklemeli). */
  nextRetryAt  DateTime?
  /** PROCESSING durumunda atanır; stuck-job recovery bu alana bakar. */
  lockedAt     DateTime?

  // ── Telemetry (cost/latency tracking) ───────────────────────────────────
  /** LLM'in input olarak gördüğü token sayısı (mevcut Ollama API'sinden çekilebiliyor). */
  inputTokens  Int?
  /** LLM'in çıktı olarak ürettiği token sayısı. */
  outputTokens Int?
  /** Toplam çağrı süresi (ms). */
  latencyMs    Int?

  user    IamUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  message MailboxMessage @relation(fields: [mailboxMessageId], references: [id], onDelete: Cascade)

  tasks          Task[]
  calendarEvents CalendarEvent[]
  reminders      Reminder[]
  suggestions    AiSuggestion[]

  @@index([userId, status])
  // mailboxMessageId zaten @unique → ayrıca @@index gereksiz
  @@index([status, nextRetryAt]) // worker'ın "şimdi işlenebilecek PENDING" sorgusu
  @@index([status, lockedAt])    // stuck-job recovery sorgusu
}

// ─── AI Suggestions (sessiz drop'ları kullanıcı kararına bırak) ──────────────

enum AiSuggestionKind {
  CANCEL
  RESCHEDULE
}

enum AiSuggestionStatus {
  PENDING   // kullanıcı kararı bekleniyor
  APPROVED  // kullanıcı onayladı, action uygulandı
  REJECTED  // kullanıcı reddetti
}

enum AiSuggestionDropReason {
  /** Update LLM tarafından üretildi ama confidence < eşik. */
  LOW_CONFIDENCE
  /** Update LLM tarafından üretildi ama EventMatcher mevcut event bulamadı. */
  NO_MATCH
}

/**
 * AI bir mailde "iptal/erteleme" sezdi ama otomatik uygulamaya güveni yok:
 * confidence eşiği altında ya da mevcut event ile eşleşme bulunamadı. Bu
 * tablo o sinyalleri "öneri" olarak persist eder; kullanıcı UI'dan onaylayıp
 * reddedebilir. Onaylanınca CANCEL / RESCHEDULE action'ı uygulanır.
 *
 * matchedEventId nullable: NO_MATCH durumunda kullanıcı manuel olarak hangi
 * event'i kastettiğini seçecek (V2). LOW_CONFIDENCE'da matcher zaten event'i
 * bulmuş olabilir, bağlanır.
 */
model AiSuggestion {
  id              String                  @id @default(cuid())
  userId          String
  aiAnalysisId    String
  kind            AiSuggestionKind
  status          AiSuggestionStatus      @default(PENDING)
  dropReason      AiSuggestionDropReason

  /** EventMatcher'ın bulduğu (varsa) mevcut event id'si. NO_MATCH'te null. */
  matchedEventId  String?

  /** LLM'in match.title alanı (kullanıcıya "hangi etkinlik?" göstermek için). */
  matchTitle      String?
  /** LLM'in mailden çıkardığı eski tarih (varsa). */
  originalStartAt DateTime?

  /** RESCHEDULE için yeni başlangıç. CANCEL'da null. */
  newStartAt      DateTime?
  newEndAt        DateTime?
  newLocation     String?

  /** LLM'in açıklaması (örn "karşı taraf iptal etti"). */
  reason          String?
  /** LLM'in update için verdiği güven (0..1). */
  confidence      Float?

  createdAt       DateTime                @default(now())
  resolvedAt      DateTime?

  user       IamUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiAnalysis AiAnalysis  @relation(fields: [aiAnalysisId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([aiAnalysisId])
}

enum TaskStatus {
  PROPOSED      // AI önerdi, kullanıcı onayı bekliyor
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id           String       @id @default(cuid())
  userId       String
  aiAnalysisId String?      // null → kullanıcı manuel oluşturdu
  title        String
  notes        String?
  dueAt        DateTime?
  rrule        String?      // RFC 5545; tekrarlayan görev (örn "her hafta rapor")
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(MEDIUM)
  /**
   * AI çıkarımının güven skoru (0..1). Manuel kayıtta null.
   * < 0.6 ise UI "AI bundan emin değil" uyarısı gösterir.
   */
  confidence   Float?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user       IamUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiAnalysis AiAnalysis? @relation(fields: [aiAnalysisId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, dueAt])
}

enum CalendarEventStatus {
  PROPOSED   // AI önerdi, kullanıcı onayı bekliyor
  PENDING    // onaylandı, dış sistem (Google Calendar) push bekliyor
  CONFIRMED  // dış sistemde de yazıldı
  CANCELLED
}

model CalendarEvent {
  id             String              @id @default(cuid())
  userId         String
  aiAnalysisId   String?
  title          String
  description    String?
  startAt        DateTime
  endAt          DateTime?
  /**
   * Saat belirsiz (mailde sadece tarih var) → all-day etkinlik. startAt
   * o günün 00:00'ına yazılır; UI saat göstermez, kullanıcı edit ile
   * saat ekleyince isAllDay=false yapılır.
   */
  isAllDay       Boolean             @default(false)
  location       String?
  attendees      String?             // JSON array string: ["a@x.com", "b@x.com"]
  rrule          String?             // RFC 5545 RRULE; tekrarlayan etkinlikler için
  timezone       String              @default("Europe/Istanbul")
  externalSystem String?             // örn "google_calendar"
  externalId     String?             // örn Google Calendar event id
  status         CalendarEventStatus @default(PROPOSED)
  /** AI çıkarımı için güven skoru (0..1); ICS davetlerinde 1.0, manuelde null. */
  confidence     Float?

  // ── Push (Google Calendar sync) telemetry & retry ───────────────────────
  /** Sync girişiminde başarısız sayısı. */
  syncAttemptCount Int       @default(0)
  /** Worker bir sonraki retry'a kadar beklesin. */
  syncNextRetryAt  DateTime?
  /** Son sync hatası — UI debug için. */
  syncErrorMessage String?

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user       IamUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiAnalysis AiAnalysis? @relation(fields: [aiAnalysisId], references: [id], onDelete: SetNull)

  @@index([userId, startAt])
  @@index([userId, status])
  /** push worker'ın "PENDING + externalId yok + retry vakti" sorgusu. */
  @@index([status, syncNextRetryAt])
}

enum ReminderStatus {
  PROPOSED      // AI önerdi, kullanıcı onayı bekliyor
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model Reminder {
  id           String         @id @default(cuid())
  userId       String
  aiAnalysisId String?
  title        String
  notes        String?

  /** Tek seferlik anımsatıcı için. */
  fireAt DateTime?

  /** RFC 5545 RRULE string (örn "FREQ=WEEKLY;BYDAY=MO"). Tekrarlayan ise dolu. */
  rrule String?

  /** IANA timezone; LLM bunu kullanıcı bağlamından alıp doldurur. */
  timezone String @default("Europe/Istanbul")

  /** Worker'ın hızlı sorgusu için pre-compute edilmiş; rrule'dan üretilir. */
  nextFireAt DateTime?

  /** Son tetiklenme zamanı (audit + duplicate koruma). */
  lastFiredAt DateTime?

  status    ReminderStatus @default(ACTIVE)
  /** AI çıkarımı için güven skoru (0..1); manuel kayıtta null. */
  confidence Float?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user       IamUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiAnalysis AiAnalysis? @relation(fields: [aiAnalysisId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, nextFireAt]) // scheduler'ın "şimdi tetiklenmesi gerekenler" sorgusu
}

enum NotificationType {
  REMINDER_FIRED
  AI_PROPOSAL
  SYSTEM
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String?
  /** Kaynağın türü: "reminder" | "calendar_event" | "task" | null (system) */
  sourceType String?
  /** Kaynak entity'nin id'si (örn Reminder.id) */
  sourceId   String?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user IamUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────

model MailboxMessage {
  id                String   @id @default(cuid())
  mailboxAccountId  String
  providerMessageId String
  /**
   * RFC 5322 `Message-ID` header değeri (`<abc@host>` formatında, açılı
   * parantezlerle birlikte). Yanıt zincirini doğru kurmak için SMTP send
   * sırasında `In-Reply-To` ve `References` header'larına basıyoruz.
   * Eski (migration öncesi) kayıtlar için null kalabilir; yanıt akışı bu
   * durumda zincir başlatamaz, kullanıcı yine de mail gönderebilir.
   */
  messageIdHeader   String?
  folder            String
  from              String?
  to                String
  subject           String?
  date              DateTime
  snippet           String?
  bodyText          String?
  bodyHtml          String?
  /**
   * RFC 5545 (.ics) ekli mailler için ham VCALENDAR içeriği. AI analizinde
   * deterministik parse edilir; varsa AI'ın calendarEvents çıktısı yerine
   * kullanılır (Outlook calendar invite vb.).
   */
  icsRaw            String?
  isRead            Boolean  @default(false)
  isStarred         Boolean  @default(false)

  /**
   * MailMind classifier (Linear SVM + TF-IDF) etiketi. 10 sınıf:
   *   "İş/Acil", "Güvenlik/Uyarı", "Pazarlama", "Sosyal Medya", "Spam",
   *   "Abonelik/Fatura", "Kişisel", "Eğitim/Öğretim", "Sağlık", "Diğer".
   * Sınıflandırma sırasında servis erişilemezse veya hata alırsa null kalır
   * (AI analizi yine de çalışır; kategori sadece ipucu).
   */
  category           String?
  /** Classifier'ın tahmin için verdiği güven skoru (0..1). */
  categoryConfidence Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mailboxAccount MailboxAccount @relation(fields: [mailboxAccountId], references: [id], onDelete: Cascade)
  aiAnalyses     AiAnalysis[]

  @@unique([mailboxAccountId, providerMessageId])
  @@index([mailboxAccountId, date])
  @@index([mailboxAccountId, isRead])
  @@index([mailboxAccountId, isStarred])
  @@index([mailboxAccountId, category])
}

// ─── Draft (taslak) mesajlar ─────────────────────────────────────────────────

model MailDraft {
  id               String  @id @default(cuid())
  userId           String
  mailboxAccountId String

  /** JSON string array: ["a@x.com", "b@y.com"] — boş taslak için null */
  toEmails  String?
  ccEmails  String?
  bccEmails String?

  subject  String?
  bodyText String?
  bodyHtml String?

  /** [{ filename, contentType, contentBase64 }] */
  attachments Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           IamUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailboxAccount MailboxAccount @relation(fields: [mailboxAccountId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([mailboxAccountId, updatedAt])
}
